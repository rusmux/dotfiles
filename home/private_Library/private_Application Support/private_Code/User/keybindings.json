[
    {
        // conflicts with Micro exit command
        "key": "ctrl+q",
        "command": "-workbench.action.quickOpenView"
    },
    {
        "key": "shift+alt+r",
        "command": "renameFile",
        "when": "explorerViewletVisible && filesExplorerFocus"
    },
    {
        "key": "shift+f6",
        "command": "-renameFile",
        "when": "explorerViewletVisible && filesExplorerFocus"
    }
]
