{
  // ? IDE
  // Window
  "window.restoreFullscreen": true,
  "window.commandCenter": false,
  "window.zoomLevel": 0.35, // increase global font size from 13 to ~14 px
  // Workbench
  "workbench.startupEditor": "none",
  "workbench.colorTheme": "One Dark Pro Night Flat",
  "workbench.colorCustomizations": {
    "gitDecoration.untrackedResourceForeground": "#e06c75"
  },
  "workbench.iconTheme": "vscode-jetbrains-icon-theme-2023-dark",
  "workbench.tree.indent": 16,
  "workbench.localHistory.maxFileSize": 512, // KB
  "workbench.editorLargeFileConfirmation": 32, // MB
  "workbench.editor.wrapTabs": true,
  "workbench.editor.empty.hint": "hidden",
  "workbench.navigationControl.enabled": false,
  "workbench.layoutControl.enabled": false,
  // Explorer
  "explorer.autoReveal": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmPasteNative": false,
  "explorer.decorations.badges": false,
  // Files
  "files.autoSave": "onFocusChange",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "files.exclude": {
    "**/.idea": true,
    // Python
    "**/__pycache__": true,
    "**/.ipynb_checkpoints": true,
    "**/.virtual_documents": true,
    "**/.ruff_cache": true,
    "**/.mypy_cache": true,
    "**/.pytest_cache": true,
    "**/*.coverage*": true
  },
  "files.watcherExclude": {
    "**/.idea": true,
    "**/node_modules": true,
    // Python
    "**/.venv": true,
    "**/__pycache__": true,
    "**/.ipynb_checkpoints": true,
    "**/.virtual_documents": true,
    "**/.ruff_cache": true,
    "**/.mypy_cache": true,
    "**/.pytest_cache": true,
    "**/*.coverage*": true
  },
  // Search
  "search.exclude": {
    "**/.venv": true
  },
  // Editor
  "breadcrumbs.enabled": false,
  "editor.fontSize": 13,
  "editor.fontFamily": "JetbrainsMono Nerd Font Mono",
  "editor.minimap.enabled": false,
  "editor.accessibilitySupport": "off",
  "editor.tabCompletion": "on",
  "editor.rulers": [
    {
      "column": 120
    }
  ],
  "diffEditor.ignoreTrimWhitespace": false,
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  // Terminal
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.scrollback": 2000,
  "terminal.integrated.stickyScroll.enabled": true,
  "terminal.integrated.tabs.title": "${cwdFolder}",
  "terminal.integrated.tabs.description": "${process}${separator}${task}${separator}${local}",
  "terminal.integrated.env.osx": {
    "Q_NEW_SESSION": "1"
  },
  // Other
  "security.workspace.trust.untrustedFiles": "open",
  "telemetry.telemetryLevel": "off",
  "redhat.telemetry.enabled": false,
  "chat.commandCenter.enabled": false,
  "yaml.format.printWidth": 120,
  // ? TOOLS
  // Git
  "git.openRepositoryInParentFolders": "never",
  "git.untrackedChanges": "separate",
  "git.autofetch": true,
  "git.autofetchPeriod": 300,
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "scminput": false
  },
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.nextEditSuggestions.fixes": true,
  "gitlens.telemetry.enabled": false,
  "gitlens.currentLine.enabled": false,
  "gitlens.views.lineHistory.avatars": false,
  "gitlens.views.fileHistory.avatars": false,
  "gitlens.views.commits.avatars": false,
  "gitlens.views.commits.showStashes": true,
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  // K8s
  "vscode-kubernetes.minikube-path-mac": "/opt/homebrew/bin/minikube",
  "vscode-kubernetes.kubectl-path-mac": "/opt/homebrew/bin/kubectl",
  "vscode-kubernetes.helm-path-mac": "/opt/homebrew/bin/helm",
  "vs-kubernetes": {
    "vs-kubernetes.crd-code-completion": "enabled",
    "vs-kubernetes.ignore-recommendations": true
  },
  // Error Lens
  "errorLens.onSave": true,
  "errorLens.excludeBySource": ["cSpell"],
  "errorLens.excludePatterns": ["**/*.ipynb"],
  "errorLens.messageTemplate": "$code: $message",
  // Shellcheck
  "shellcheck.executablePath": "/opt/homebrew/bin/shellcheck",
  "shellcheck.ignorePatterns": {
    "**/*.zsh": false,
    "**/*.zshrc": false,
    "**/zshrc": false,
    "**/*.zprofile": false,
    "**/zprofile": false,
    "**/*.zshenv": false,
    "**/zshenv": false
  },
  "shellcheck.run": "onSave",
  "shellcheck.customArgs": ["-x"],
  // Other
  "cSpell.language": "en,ru",
  "cSpell.spellCheckDelayMs": 100,
  "cSpell.diagnosticLevel": "Hint",
  "path-intellisense.showHiddenFiles": true,
  "path-intellisense.autoTriggerNextSuggestion": true,
  "c4.diagram.structurizr.enabled": true,
  "c4.diagram.renderer": "structurizr",
  "docker.extension.dockerEngineAvailabilityPrompt": false,
  "hediet.vscode-drawio.offline": false,
  // ? LANGUAGES
  // Python
  "ruff.nativeServer": true,
  "python.analysis.typeCheckingMode": "strict",
  "[python]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    }
  },
  "jupyter.disableJupyterAutoStart": true,
  "jupyter.askForKernelRestart": false
}
